<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/holder_tv_wl_tt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/_6sdp"
        android:textSize="@dimen/_20sdp"
        android:textColor="@color/black"
        android:text="趣味词汇" />

    <ProgressBar
        android:id="@+id/wl_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="@dimen/_12sdp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/holder_tv_wl_tt"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginHorizontal="@dimen/_30sdp"
        android:progressDrawable="@drawable/progress_bar_ns"
        android:progress="0"/>

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="@id/wl_progress_bar"
        app:layout_constraintBottom_toTopOf="@id/wl_progress_bar"
        android:text="1/3"
        android:textSize="@dimen/_12sdp"
        android:textColor="@color/black"/>

    <ImageButton
        android:id="@+id/btn_play"
        android:layout_width="@dimen/_54sdp"
        android:layout_height="@dimen/_54sdp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/wl_progress_bar"
        android:layout_marginTop="@dimen/_20sdp"
        android:background="@drawable/ic_play_sound_gray"
        android:contentDescription="播放语音" />

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_play"
        android:text="听发音，选择正确的词汇"
        android:textSize="@dimen/_12sdp"
        android:textColor="@color/gray_opacity"
        android:layout_marginTop="@dimen/_6sdp"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:id="@+id/options_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_hint"
        android:layout_marginTop="@dimen/_12sdp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginHorizontal="20dp" />

    <TextView
        android:id="@+id/tv_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/options_container"
        android:text="得分：0"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_marginTop="24dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
