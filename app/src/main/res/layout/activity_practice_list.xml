<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Layout.Assessment.PracticeList">

    <TextView
        android:id="@+id/practice_list_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/_10sdp"
        android:textSize="@dimen/_20sdp"
        android:textColor="@color/black"
        android:text="词汇练习" />

    <View
        android:id="@+id/pc_lt_l_v"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_6sdp"
        app:layout_constraintTop_toBottomOf="@id/practice_list_title"
        android:layout_marginTop="@dimen/_8sdp"
        android:background="@drawable/green_bg" />
    <TextView
        android:id="@+id/pc_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pc_lt_l_v"
        android:textSize="@dimen/_12sdp"
        android:textColor="@color/gray_opacity"
        android:text="点击选择要练习的句子" />

    <CheckBox
        android:id="@+id/practice_list_choose_all"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_18sdp"
        app:layout_constraintBottom_toTopOf="@id/pc_lt_l_v"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="@dimen/_10sdp"
        android:textColor="@color/black"
        android:text="全选" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/practice_list_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/pc_tip"
        app:layout_constraintBottom_toTopOf="@id/practice_list_start"
        android:layout_marginVertical="@dimen/_4sdp"/>

    <TextView
        android:id="@+id/practice_list_start"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_34sdp"
        android:background="@drawable/green_bg"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="@dimen/_40sdp"
        android:textSize="@dimen/_18sdp"
        android:textColor="@color/white"
        android:gravity="center"
        android:text="开始" />

    <View
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_40sdp"
        app:layout_constraintBottom_toBottomOf="@id/practice_list_start"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="@dimen/_10sdp"
        android:background="@drawable/dog" />

</androidx.constraintlayout.widget.ConstraintLayout>