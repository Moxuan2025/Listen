<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Layout.EnjoyStudy.SpellPractise">

    <TextView
        android:id="@+id/tv_spell_practise_target"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_90sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintVertical_bias="0.02"
        android:gravity="center"
        android:text="bang"
        android:textColor="@color/black"
        android:textSize="@dimen/_60sdp" />

    <TextView
        android:id="@+id/tv_spell_practise_counter"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/tv_spell_practise_target"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginBottom="@dimen/_10sdp"
        android:gravity="center"
        android:text="1/21"
        android:textSize="@dimen/_18sdp"
        android:textColor="@color/black" />

    <VideoView
        android:id="@+id/pv_example_view"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_200sdp"
        android:layout_margin="@dimen/_18sdp"
        app:layout_constraintTop_toBottomOf="@id/tv_spell_practise_target" />

    <Button
        android:id="@+id/bt_spell_pre"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_40sdp"
        android:backgroundTint="@color/yellow_bt"
        app:layout_constraintTop_toBottomOf="@id/pv_example_view"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        android:text="上一个"
        android:textSize="@dimen/_12sdp"
        android:textColor="@color/black" />

    <Button
        android:id="@+id/bt_spell_nxt"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_40sdp"
        android:backgroundTint="@color/yellow_bt"
        app:layout_constraintTop_toBottomOf="@id/pv_example_view"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintHorizontal_bias="0.9"
        android:text="下一个"
        android:textSize="@dimen/_12sdp"
        android:textColor="@color/black" />

    <Button
        android:id="@+id/bt_try_report"
        android:layout_width="@dimen/_140sdp"
        android:layout_height="@dimen/_50sdp"
        android:backgroundTint="@color/bt_green"
        app:layout_constraintTop_toBottomOf="@id/bt_spell_nxt"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="@dimen/_20sdp"
        android:text="尝试"
        android:textColor="@color/white"
        android:textSize="@dimen/_18sdp" />

</androidx.constraintlayout.widget.ConstraintLayout>