<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_40sdp"
    android:orientation="horizontal"
    android:gravity="center_vertical" >

    <TextView
        android:id="@+id/rank_rank"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="1"
        android:textSize="@dimen/_20sdp" />
    <TextView
        android:id="@+id/rank_name"
        android:layout_width="@dimen/_100sdp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:text="##"
        android:textSize="@dimen/_20sdp" />
    <View
        android:id="@+id/rank_avatar"
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_40sdp"
        android:background="@drawable/avatar_default" />
    <TextView
        android:id="@+id/rank_clockin_days"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rank_clockin"
        android:text="打卡天数:0"
        android:textColor="@color/bt_green"
        android:gravity="center_vertical"
        android:paddingRight="@dimen/_24sdp"
        android:paddingLeft="@dimen/_5sdp" />

</LinearLayout>