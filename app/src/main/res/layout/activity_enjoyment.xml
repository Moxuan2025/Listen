<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Layout.EnjoyStudy.Enjoyment">

    <View
        android:id="@+id/blank_view_bottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_140sdp"
        android:background = "@drawable/light_green_bg"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginVertical="@dimen/_16sdp"
        android:layout_marginHorizontal="@dimen/_16sdp"/>
    <View
        android:id="@+id/blank_view_top"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_60sdp"
        app:layout_constraintBottom_toBottomOf="@+id/blank_view_bottom"
        android:layout_marginBottom="@dimen/_30sdp"
        android:layout_marginHorizontal="@dimen/_40sdp"
        android:background="@drawable/green_bg" />
    <ImageView
        android:id="@+id/enjoyment_dog"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_80sdp"
        app:layout_constraintBottom_toBottomOf="@id/blank_view_top"
        app:layout_constraintRight_toRightOf="@id/blank_view_top"
        android:src="@drawable/dog" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/blank_view_top"
        app:layout_constraintBottom_toBottomOf="@id/blank_view_top"
        app:layout_constraintLeft_toLeftOf="@id/blank_view_top"
        android:layout_marginLeft="@dimen/_14sdp"
        android:gravity="left"
        android:textSize="@dimen/_14sdp"
        android:textColor="@color/white"
        android:text="“坚持是一种习惯”\n\t\t--致每天努力的自己" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/blank_view_top"
        app:layout_constraintRight_toLeftOf="@id/enjoyment_clockin_days"
        android:text="累计打卡"
        android:textColor="@color/white"
        android:textSize="@dimen/_18sdp" />
    <TextView
        android:id="@+id/enjoyment_clockin_days"
        android:layout_width="@dimen/_40sdp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/blank_view_top"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintHorizontal_bias="0.46"
        android:gravity="center_horizontal"
        android:text="1"
        android:textSize="@dimen/_22sdp"
        android:textColor="@color/yellow_dk" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/blank_view_top"
        app:layout_constraintLeft_toRightOf="@id/enjoyment_clockin_days"
        android:text="天"
        android:textColor="@color/white"
        android:textSize="@dimen/_18sdp" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/blank_view_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginVertical="@dimen/_16sdp"
        android:layout_marginHorizontal="@dimen/_16sdp"
        android:orientation="vertical" >
        <TextView
            android:id="@+id/tv_enjoy_syllable"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_66sdp"
            android:background="@drawable/green_bg"
            android:gravity="center_vertical|left"
            android:layout_marginVertical="@dimen/_8sdp"
            android:text="趣味拼音"
            android:textSize="@dimen/_26sdp"
            android:paddingLeft="@dimen/_60sdp"
            android:textColor="@color/white" />
        <TextView
            android:id="@+id/tv_enjoy_word"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_66sdp"
            android:background="@drawable/green_bg"
            android:gravity="center_vertical|right"
            android:layout_marginVertical="@dimen/_8sdp"
            android:text="趣味词汇"
            android:textSize="@dimen/_26sdp"
            android:paddingRight="@dimen/_60sdp"
            android:textColor="@color/white" />
        <TextView
            android:id="@+id/tv_condition_practice"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_66sdp"
            android:background="@drawable/green_bg"
            android:gravity="center_vertical|left"
            android:layout_marginVertical="@dimen/_8sdp"
            android:text="情景练习"
            android:textSize="@dimen/_26sdp"
            android:paddingLeft="@dimen/_60sdp"
            android:textColor="@color/white" />
        <TextView
            android:id="@+id/tv_enjoy_phrase"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_66sdp"
            android:background="@drawable/green_bg"
            android:gravity="center_vertical|right"
            android:layout_marginVertical="@dimen/_8sdp"
            android:text="趣味段落"
            android:textSize="@dimen/_26sdp"
            android:paddingRight="@dimen/_60sdp"
            android:textColor="@color/white" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>