<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".Layout.EnjoyStudy.FragmentPracticeContent">

    <ImageView
        android:id="@+id/example_view"
        android:layout_width="@dimen/_160sdp"
        android:layout_height="@dimen/_80sdp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_blackboard"/>
    <TextView
        android:id="@+id/practice_content_label"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintRight_toRightOf="@id/example_view"
        app:layout_constraintLeft_toLeftOf="@id/example_view"
        app:layout_constraintTop_toTopOf="@id/example_view"
        app:layout_constraintBottom_toBottomOf="@id/example_view"
        android:paddingBottom="@dimen/_6sdp"
        android:gravity="center"
        android:textColor="@color/white_op"
        android:textSize="@dimen/_16sdp"
        android:text="你好世界" />

    <LinearLayout
        android:id="@+id/ll_pc_top"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_40sdp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/example_view"
        android:layout_marginTop="@dimen/_6sdp"
        android:orientation="horizontal"
        android:gravity="center" >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="@dimen/_14sdp"
            android:textColor="@color/gray_opacity"
            android:text="播放示例:"/>
        <ImageView
            android:id="@+id/example_sound_play"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"
            android:background="@drawable/ic_play_sound_gray"
            android:layout_marginLeft="@dimen/_10sdp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_pc"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_30sdp"
        app:layout_constraintTop_toBottomOf="@id/ll_pc_top"
        android:layout_marginTop="@dimen/_4sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:gravity="center" >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="@dimen/_16sdp"
            android:textColor="@color/black"
            android:text="你的分数：" />
        <TextView
            android:id="@+id/practice_score"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="@dimen/_20sdp"
            android:textColor="@color/black"
            android:text="--" />
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="@dimen/_16sdp"
            android:textColor="@color/black"
            android:text="点击播放:" />
        <ImageView
            android:id="@+id/record_sound_play"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:src="@drawable/ic_play_sound_gray"
            android:scaleX="0.8"
            android:scaleY="0.8" />
    </LinearLayout>

    <TextView
        android:id="@+id/spell_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/ll_pc"
        android:layout_marginTop="@dimen/_4sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:background="@color/bt_green"
        android:paddingHorizontal="@dimen/_8sdp"
        android:paddingVertical="@dimen/_6sdp"
        android:textSize="@dimen/_14sdp"
        android:textColor="@color/white"
        android:text="test\n测试"/>

    <LinearLayout
        android:id="@+id/ll_pc_sr"
        android:layout_width="@dimen/_50sdp"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/spell_action"
        android:layout_marginTop="@dimen/_10sdp"
        android:gravity="center"
        android:orientation="vertical">
        <ImageButton
            android:id="@+id/practise_sound_record"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_50sdp"
            android:background="@drawable/ic_record_gray" />
        <TextView
            android:id="@+id/practise_sound_record_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="@dimen/_10sdp"
            android:textColor="@color/gray_opacity"
            android:text="按住说话" />
    </LinearLayout>

    <TextView
        android:id="@+id/pc_pre"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_34sdp"
        app:layout_constraintTop_toBottomOf="@id/ll_pc_sr"
        android:layout_marginTop="@dimen/_10sdp"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="@dimen/_50sdp"
        android:background="@drawable/bg_yellow_round"
        android:textSize="@dimen/_14sdp"
        android:textColor="@color/black"
        android:gravity="center"
        android:text="上一个" />

    <TextView
        android:id="@+id/pc_nxt"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_34sdp"
        app:layout_constraintTop_toBottomOf="@id/ll_pc_sr"
        android:layout_marginTop="@dimen/_10sdp"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="@dimen/_50sdp"
        android:background="@drawable/bg_yellow_round"
        android:textSize="@dimen/_14sdp"
        android:textColor="@color/black"
        android:gravity="center"
        android:text="下一个" />

    <View
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_40sdp"
        app:layout_constraintTop_toTopOf="@id/ll_pc_sr"
        app:layout_constraintBottom_toBottomOf="@id/ll_pc_sr"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="@dimen/_20sdp"
        android:background="@drawable/dog"/>


</androidx.constraintlayout.widget.ConstraintLayout>