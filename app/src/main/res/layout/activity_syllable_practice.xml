<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Layout.EnjoyStudy.SyllablePractice">

    <TextView
        android:id="@+id/tv_syllable_target"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_90sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintVertical_bias="0.02"
        android:gravity="center"
        android:text="b"
        android:textColor="@color/black"
        android:textSize="@dimen/_70sdp" />

    <TextView
        android:id="@+id/process"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/tv_syllable_target"
        app:layout_constraintBottom_toBottomOf="@id/tv_syllable_target"
        android:gravity="center_vertical|right"
        android:paddingRight="@dimen/_40sdp"
        android:text="1/21"
        android:textSize="@dimen/_18sdp"
        android:textColor="@color/black" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/tv_syllable_target"
        app:layout_constraintBottom_toTopOf="@id/process"
        android:gravity="center_vertical|right"
        android:paddingRight="@dimen/_20sdp"
        android:text="声母练习"
        android:textSize="@dimen/_18sdp"
        android:textColor="@color/black" />

    <GridLayout
        android:id="@+id/gl_syllable_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tv_syllable_target"
        android:layout_marginVertical="@dimen/_16sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:background="@drawable/light_green_bg" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/gl_syllable_group"
        android:layout_marginVertical="@dimen/_8sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_3sdp" >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/_2sdp">
                <TextView
                    android:layout_width="@dimen/_60sdp"
                    android:layout_height="@dimen/_60sdp"
                    android:background="@drawable/star"
                    android:scaleX="0.8"
                    android:scaleY="0.8" />
                <View
                    android:layout_width="@dimen/_5sdp"
                    android:layout_height="match_parent"
                    android:background="@color/bt_green" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background = "@drawable/green_bar_bg"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:padding="@dimen/_3sdp">
                    <TextView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="词汇"
                        android:textSize="@dimen/_18sdp"
                        android:textColor="@color/white" />
                    <View
                        android:layout_width="@dimen/_2sdp"
                        android:layout_height="match_parent"
                        android:background = "@drawable/white_bar_bg"
                        android:layout_marginLeft="@dimen/_3sdp" />
                    <TextView
                        android:id="@+id/tv_syllable_word"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:gravity="left|center_vertical"
                        android:text="（一）请输入文本\n（二）请输入文本"
                        android:textSize="@dimen/_12sdp"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/_2sdp">
                <TextView
                    android:layout_width="@dimen/_60sdp"
                    android:layout_height="@dimen/_60sdp"
                    android:background="@drawable/star"
                    android:scaleX="0.8"
                    android:scaleY="0.8" />
                <View
                    android:layout_width="@dimen/_5sdp"
                    android:layout_height="match_parent"
                    android:background="@color/bt_green" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background = "@drawable/green_bar_bg"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:padding="@dimen/_3sdp">
                    <TextView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="句子"
                        android:textSize="@dimen/_18sdp"
                        android:textColor="@color/white" />
                    <View
                        android:layout_width="@dimen/_2sdp"
                        android:layout_height="match_parent"
                        android:background = "@drawable/white_bar_bg"
                        android:layout_marginLeft="@dimen/_3sdp" />
                    <TextView
                        android:id="@+id/tv_syllable_sentence"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:gravity="left|center_vertical"
                        android:text="（一）请输入文本\n（二）请输入文本"
                        android:textSize="@dimen/_12sdp"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/_2sdp">
                <TextView
                    android:layout_width="@dimen/_60sdp"
                    android:layout_height="@dimen/_60sdp"
                    android:background="@drawable/star"
                    android:scaleX="0.8"
                    android:scaleY="0.8" />
                <View
                    android:layout_width="@dimen/_5sdp"
                    android:layout_height="match_parent"
                    android:background="@color/bt_green" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background = "@drawable/green_bar_bg"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:padding="@dimen/_3sdp">
                    <TextView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="文段"
                        android:textSize="@dimen/_18sdp"
                        android:textColor="@color/white" />
                    <View
                        android:layout_width="@dimen/_2sdp"
                        android:layout_height="match_parent"
                        android:background = "@drawable/white_bar_bg"
                        android:layout_marginLeft="@dimen/_3sdp" />
                    <TextView
                        android:id="@+id/tv_syllable_section"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="@dimen/_3sdp"
                        android:gravity="left|center_vertical"
                        android:text="（一）请输入文本\n（二）请输入文本"
                        android:textSize="@dimen/_12sdp"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>