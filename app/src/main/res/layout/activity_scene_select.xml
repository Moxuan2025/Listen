<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Layout.Assessment.SceneSelect">

    <TextView
        android:id="@+id/scene_select_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_60sdp"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center"
        android:text="社 区 排 名 榜"
        android:textSize="@dimen/_26sdp"
        android:textColor="@color/black"/>

    <LinearLayout
        android:id="@+id/tv_scene_select_section"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_40sdp"
        app:layout_constraintTop_toBottomOf="@id/scene_select_title"
        android:orientation="horizontal"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:layout_marginTop="@dimen/_14sdp">
        <TextView
            android:id="@+id/tv_scene_school"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_frank_navi_yellow"
            android:layout_weight="1"
            android:gravity="center"
            android:text="校园情景"
            android:textColor="@color/white"
            android:textSize="@dimen/_16sdp"
            android:paddingBottom="@dimen/_10sdp" />
        <TextView
            android:id="@+id/tv_scene_life"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_frank_navi_green"
            android:layout_weight="1"
            android:gravity="center"
            android:text="日常情景"
            android:textColor="@color/white"
            android:textSize="@dimen/_16sdp"
            android:paddingBottom="@dimen/_10sdp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rank_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_scene_select_section"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="@dimen/_minus16sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:background="@color/bt_green" />

</androidx.constraintlayout.widget.ConstraintLayout>