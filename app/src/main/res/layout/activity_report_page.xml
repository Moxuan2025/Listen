<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Layout.ReportPage">

    <TextView
        android:id="@+id/holder_tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginVertical="@dimen/_4sdp"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="@dimen/_20sdp"
        android:text="综合报告"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_4sdp" />

    <com.github.mikephil.charting.charts.RadarChart
        android:id="@+id/report_radar_chart"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginHorizontal="@dimen/_40sdp"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintTop_toBottomOf="@id/holder_tv_title"/>

    <TextView
        android:id="@+id/report_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/report_radar_chart"
        android:layout_marginVertical="@dimen/_6sdp"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="@dimen/_20sdp"
        android:text="综合分数: 99"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_4sdp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/report_score"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/report_listening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="听力能力: 0"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/report_listening_level"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="听力等级: 0"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/report_expression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="表达能力: 0"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/report_comprehension"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="理解能力: 0"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/report_overall_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="综合评分: 0"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/report_back"
        android:layout_width="@dimen/_100sdp"
        android:layout_height="@dimen/_34sdp"
        android:background="@drawable/bg_yellow_round"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center"
        android:layout_marginBottom="@dimen/_30sdp"
        android:textSize="@dimen/_16sdp"
        android:textColor="@color/black"
        android:paddingHorizontal="@dimen/_10sdp"
        android:text="返回" />

    <View
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_40sdp"
        android:background="@drawable/dog"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="@dimen/_10sdp" />

</androidx.constraintlayout.widget.ConstraintLayout>