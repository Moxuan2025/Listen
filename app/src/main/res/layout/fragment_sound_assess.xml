<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Layout.Assessment.FragmentSoundAssess">

    <ImageButton
        android:id="@+id/bt_sound_assessment_back"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:background="@drawable/back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintHorizontal_bias="0.02" />

    <TextView
        android:id="@+id/lb_sound_assessment_title"
        android:layout_width="@dimen/_200sdp"
        android:layout_height="@dimen/_30sdp"
        android:gravity="center"
        android:text="听力评估"
        android:textColor="@color/black"
        android:textSize="@dimen/_20sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintHorizontal_bias="0.5" />

    <TextView
        android:id="@+id/ai_consultant"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_100sdp"
        android:background="@drawable/sound_evaluate_ai_consultant_bg"
        android:gravity="left|center_vertical"
        android:padding="@dimen/_10sdp"
        android:text="小智客服服务\n小智为你全面服务\n可联系热线：666-666-6666"
        android:textSize="@dimen/_14sdp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.64"
        android:layout_marginHorizontal="@dimen/_16sdp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:columnCount="2"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@id/lb_sound_assessment_title"
        app:layout_constraintBottom_toTopOf="@id/ai_consultant"
        android:padding="@dimen/_16sdp" >
        <TextView
            android:id="@+id/device_eval"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/_6sdp"
            android:background="@drawable/sound_evaluate_bg"
            android:gravity="left|top"
            android:padding="@dimen/_10sdp"
            android:text="设备调听\n评估设备效果"
            android:textSize="@dimen/_14sdp"
            android:textColor="@color/white"/>
        <TextView
            android:id="@+id/tv_sound_practice"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/_6sdp"
            android:background="@drawable/sound_evaluate_bg"
            android:gravity="left | top"
            android:padding="@dimen/_10sdp"
            android:text="听能训练\n能听到声音吗"
            android:textSize="@dimen/_14sdp"
            android:textColor="@color/white"/>
        <TextView
            android:id="@+id/story_test"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/_6sdp"
            android:background="@drawable/sound_evaluate_bg"
            android:gravity="left | top"
            android:padding="@dimen/_10sdp"
            android:text="情景测听\n听故事测听力"
            android:textSize="@dimen/_14sdp"
            android:textColor="@color/white"/>
        <TextView
            android:id="@+id/tv_professional_assess"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/_6sdp"
            android:background="@drawable/sound_evaluate_bg"
            android:gravity="left | top"
            android:padding="@dimen/_10sdp"
            android:text="专业听力筛查\n专业化自测"
            android:textSize="@dimen/_14sdp"
            android:textColor="@color/white"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>